# Validator .env — operator-local fields only.
# Chain facts (RPC, mailbox, gas) live in ../chain.yaml — DON'T put
# them here. The kit pre-sets them so adding a chain to YOUR fleet
# is: cd chains/<key>/validator && cp .env.example .env && drive.sh up

# ─────────── Identity ───────────
# Short label used in container names + status output. Lowercase
# alphanumeric + dashes only. Pick a unique one per operator.
OPERATOR_NAME=

# ─────────── Validator signing key ───────────
# Generated by 01_setup.sh. Never share. Never reuse.
# Format: 0x-prefixed hex, 32 bytes. AUTO-FILLED — do not paste manually.
VALIDATOR_KEY=

# ─────────── Signature storage backend ───────────
# Pick ONE — the agent writes signed checkpoints there, the relayer
# reads from the same backend.
#
#   CHECKPOINT_SYNCER_TYPE=s3            ← Cloudflare R2 / AWS S3 (production)
#   CHECKPOINT_SYNCER_TYPE=localStorage  ← bind-mounted host dir (single-box pilots)
CHECKPOINT_SYNCER_TYPE=s3

# Public-read URL of your sig storage — relayers pull from here.
# For S3:           https://<bucket>.r2.cloudflarestorage.com  (or AWS equivalent)
# For localStorage: file://${LOCAL_SIG_DIR}/${OPERATOR_NAME}   (relayer must share filesystem)
BUCKET_URL=

# ─────────── S3 / R2 fields (only when CHECKPOINT_SYNCER_TYPE=s3) ───────────
# For Cloudflare R2 (recommended — free tier covers expected volume):
#   1) Create bucket at dash.cloudflare.com → R2
#   2) Set bucket policy to public-read on /${CHAIN_KEY}/* and /announcement.json
#   3) Create an API token scoped to this bucket with Object Read+Write
CHECKPOINT_SYNCER_BUCKET=
CHECKPOINT_SYNCER_REGION=auto
CHECKPOINT_SYNCER_ACCESS_KEY=
CHECKPOINT_SYNCER_SECRET_KEY=
# Required for R2; omit for AWS S3.
# Format: https://<account-id>.r2.cloudflarestorage.com
CHECKPOINT_SYNCER_ENDPOINT=

# ─────────── localStorage fields (only when CHECKPOINT_SYNCER_TYPE=localStorage) ───────────
# Host path bind-mounted into the validator + relayer containers.
LOCAL_SIG_DIR=/srv/hyperlane-sigs

# ─────────── Optional: private RPC override ───────────
# Set this to use your own node / VPN / paid plan instead of the
# public RPCs declared in ../chain.yaml. Variable name is the chain
# key uppercased with dashes → underscores + suffix _RPC. drive.sh
# auto-detects which one to forward.
# Example for chain key `example-chain`:
#   EXAMPLE_CHAIN_RPC=https://my-private-node.example.org:8545

# ─────────── Agent runtime ───────────
HYPERLANE_AGENT_IMAGE=gcr.io/abacus-labs-dev/hyperlane-agent:main
LOG_LEVEL=info

# ─────────── Self-monitoring (optional but recommended) ───────────
# Webhook called when YOUR signing lag exceeds 1 minute or bucket
# becomes unreachable. There is no central alerting — uptime is your
# responsibility.
ALERT_WEBHOOK=
