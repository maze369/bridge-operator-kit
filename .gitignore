# Per-operator secrets — never commit
**/.env
*.key
*.pem

# Auto-generated from chains/*/chain.yaml on every drive.sh up — no need
# to commit; the next drive.sh run reproduces it.
shared/agent-config.json

# Auto-generated by relayer/drive.sh on every up — per-chain signer +
# RPC envvars rendered from chains/*/chain.yaml + relayer/.env.
relayer/.env-chains

# Generated outputs (operator-specific, ephemeral)
validator/02_fund_keys.md
relayer/02_fund_keys.md
deployer/*_evm_core.json
deployer/warp_*.json
deployer/*_result.json
deployer/ism_history.json
# Phase 2/3 emit artifacts (Safe transactions, Governor proposals) —
# operator-specific, may include sensitive authorization context.
deployer/artifacts/

# Per-operator instance dirs (rehearsal artifacts — local only)
validator-v*/
relayer-r*/

# Operator-scratch helpers (anything prefixed with `_` is not part of the kit).
# Exception: `deployer/_run_deploy.sh` is the core docker-runner wrapper.
tools/_*

# Node + Python
**/node_modules/
**/__pycache__/
**/*.pyc
**/package-lock.json

# Editor / OS
.DS_Store
*.swp
*~
.vscode/
.idea/

# Local logs
*.log
