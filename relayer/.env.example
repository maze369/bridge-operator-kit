# Relayer operator config — copy to .env and edit.
# See ../runbooks/ADD_RELAYER.md for the onboarding flow.

# ─────────── Identity ───────────
# Short label used in container names. Lowercase + dashes only.
OPERATOR_NAME=

# ─────────── Chains ───────────
# Comma-separated chain keys this relayer will deliver to. Keys must
# match a chains/<key>/ preset (where chain.yaml's `key:` == this name).
#
# Leaving RELAY_CHAINS empty defaults to "every preset chain" — fine
# for full coverage; set explicitly if you only want to relay a subset.
RELAY_CHAINS=example-mainnet,example-testnet

# ─────────── Stagger sidecar ───────────
# Delay (ms) before this relayer submits process(). Picks your TIER.
# Coordinate in the operator channel — two relayers at the same tier
# = gas wars.
#
#   0     = primary    — pays ~100% of gas, no failover lag
#   15000 = warm spare — ~0% gas in steady state, +15s failover lag
#   30000 = cold spare — ~0% gas, +30s failover lag
#   60000+= extra      — only fires when 3+ relayers above die
RELAYER_DELAY_MS=15000

# Allow validators publishing to LOCAL file checkpoints (vs HTTP buckets).
# Harmless if all validators use HTTP. Required if any use a local syncer.
HYP_ALLOWLOCALCHECKPOINTSYNCERS=true

# Optional whitelist: only attempt delivery for messages whose
# destination router is in this list. Use this when sharing a Mailbox
# with another bridge to avoid attempting delivery of foreign messages.
# Leave empty for "all messages."
# Format: <chain1>:<router1>,<chain2>:<router2>,...
HYP_RELAYER_WHITELIST=

# ─────────── Per-chain signer keys ───────────
# AUTO-FILLED by 01_setup.sh — do not paste manually.
# One key per chain (so a compromise on one chain doesn't expose another).
#
# Format: SIGNER_KEY_<UPPERCASE_CHAINKEY>=0x...
# Example (chain key with dashes → underscores):
#   SIGNER_KEY_EXAMPLE_MAINNET=0x...
#   SIGNER_KEY_EXAMPLE_TESTNET=0x...

# ─────────── Optional: private RPC overrides ───────────
# Set this if you want to use your own node / VPN / paid plan for a
# chain instead of the public RPCs in chain.yaml. Variable name =
# <CHAIN_KEY_UPPER>_RPC. drive.sh auto-detects.
# Example for chain key `example-mainnet`:
#   EXAMPLE_MAINNET_RPC=https://my-private-node.example.org:8545

# ─────────── Agent runtime ───────────
HYPERLANE_AGENT_IMAGE=gcr.io/abacus-labs-dev/hyperlane-agent:main
LOG_LEVEL=info

# ─────────── Self-monitoring ───────────
# Webhook called when pending message count exceeds threshold OR any
# signer balance drops below threshold (Hyperlane has no central alert).
ALERT_WEBHOOK=
PENDING_ALERT_THRESHOLD=10
LOW_BALANCE_ALERT_RATIO=0.25

# ─────────── localStorage sig dir (only when relaying for localStorage validators) ───────────
# Host path bind-mounted read-only into the relayer container so it can
# fetch validators' file:// announced sig URLs. MUST match the LOCAL_SIG_DIR
# of every same-host validator you're relaying for. Harmless if all
# validators publish to S3/R2 — the mount is a no-op.
LOCAL_SIG_DIR=/srv/hyperlane-sigs
